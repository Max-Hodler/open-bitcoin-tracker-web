---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, resolveLang } from '../i18n/utils';

const repoUrl = 'https://github.com/Max-Hodler/open-bitcoin-tracker';
const releasesUrl = 'https://github.com/Max-Hodler/open-bitcoin-tracker/releases/latest';

const t = useTranslations(Astro.currentLocale);
const lang = resolveLang(Astro.currentLocale);
const homeHref = getRelativeLocaleUrl(lang, '');
---

<header class="nav-header sticky top-0 left-0 right-0 z-50">
  <nav class="site-container flex items-center justify-between py-4">
    <a href={homeHref} class="flex items-center gap-2.5 text-ink hover:opacity-80 transition-opacity duration-200">
      <img src="/app-icon.png" width="28" height="28" alt="" />
      <span class="font-semibold tracking-tight text-[15px]">Open Bitcoin Tracker</span>
    </a>
    <div class="flex items-center gap-4 sm:gap-6 text-sm text-ink-muted">
      <a
        href={repoUrl}
        rel="noopener"
        class="hidden items-center gap-1.5 hover:text-ink sm:inline-flex transition-colors duration-200 text-[13px]"
        aria-label={t.nav.githubAria}
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.11.82-.26.82-.577v-2.234c-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.332-1.756-1.332-1.756-1.09-.745.083-.729.083-.729 1.205.085 1.84 1.237 1.84 1.237 1.07 1.835 2.807 1.305 3.492.998.108-.776.418-1.305.762-1.605-2.665-.3-5.467-1.332-5.467-5.93 0-1.31.468-2.382 1.236-3.222-.124-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.3 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.29-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.873.118 3.176.77.84 1.235 1.912 1.235 3.222 0 4.61-2.807 5.625-5.48 5.92.43.372.814 1.102.814 2.222v3.293c0 .32.218.694.825.576C20.565 21.795 24 17.298 24 12c0-6.63-5.37-12-12-12z"/></svg>
        {t.nav.github}
      </a>
      <a
        href={releasesUrl}
        rel="noopener"
        class="rounded-lg bg-accent px-3.5 py-1.5 text-[13px] font-semibold text-white hover:opacity-90 transition-opacity duration-200 shadow-sm"
      >
        {t.nav.download}
      </a>
    </div>
  </nav>
</header>

<style>
  .nav-header {
    background: var(--nav-bg);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border-bottom: 1px solid var(--nav-border);
  }
</style>
